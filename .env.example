# ==============================================
# Argus - AI SRC 漏洞挖掘系统 环境变量配置
# 复制此文件为 .env 并填入实际值
# ==============================================

# 数据库连接（异步 PostgreSQL）
DATABASE_URL=postgresql+asyncpg://argus:argus_dev_password@localhost:5432/argus

# Redis 连接
REDIS_URL=redis://localhost:6379/0

# NATS 消息总线连接
NATS_URL=nats://localhost:4222

# Anthropic API 密钥（用于 Claude AI Agent）
ANTHROPIC_API_KEY=sk-ant-xxxxx

# JWT 认证配置
JWT_SECRET=your-super-secret-key-change-in-production

# 调试模式
DEBUG=true

# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
